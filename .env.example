# ============================================================
# SURVEYOR — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------- Application ----------
APP_NAME=SURVEYOR
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true

# ---------- PostgreSQL ----------
POSTGRES_USER=surveyor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=surveyor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- AI Providers ----------
# At minimum, configure one LLM provider.

# OpenAI (also used for Realtime API in Path A)
OPENAI_API_KEY=

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=

# ---------- Telephony (Optional) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------- LiteLLM (Optional overrides) ----------
# Add any additional provider keys here.
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
# MISTRAL_API_KEY=

# ---------- Caddy ----------
# Domain for production SSL. Use localhost for local development.
DOMAIN=localhost

# ---------- Authentication (Optional) ----------
# Set AUTH_ENABLED=true to require login for the admin dashboard.
# Default: false (no login required)
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=

# ---------- Google AI (Gemini Live) ----------
GOOGLE_API_KEY=

# ---------- Scaleway (Optional) ----------
SCALEWAY_SECRET_KEY=
SCALEWAY_PROJECT_ID=
SCALEWAY_API_URL=https://api.scaleway.ai/v1

# ---------- Azure OpenAI (Optional — self-hosted) ----------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ---------- GCP Vertex AI (Optional — self-hosted) ----------
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_API_KEY=

# ---------- Self-Hosted STT/TTS (Optional — on-prem or cloud) ----------
# Point these at any OpenAI-compatible STT/TTS server.
# Examples: Speaches (faster-whisper), Kokoro, Piper, LocalAI, etc.
SELF_HOSTED_STT_URL=
SELF_HOSTED_STT_API_KEY=
SELF_HOSTED_STT_MODEL=whisper-1
SELF_HOSTED_TTS_URL=
SELF_HOSTED_TTS_API_KEY=
SELF_HOSTED_TTS_MODEL=tts-1

# ---------- Embeddings / RAG (Optional) ----------
# Leave empty to use OpenAI's text-embedding-3-small (requires OPENAI_API_KEY).
# Set EMBEDDING_API_URL to use any OpenAI-compatible embedding server instead.
# NOTE: The DB schema expects 1536-dimensional vectors. If your model outputs
# a different dimension, you'll need a database migration.
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
